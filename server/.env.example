# Copy to .env and adjust. For local dev you can leave DATABASE_URL empty and
# rely on the embedded Postgres (EMBEDDED_PG=1, set automatically by `npm run dev`).

PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173

# Production (e.g. Cloud Run + Cloud SQL): point at your managed Postgres.
# DATABASE_URL=postgresql://user:pass@host:5432/baller
# NODE_ENV=production
# CLIENT_DIST=/app/client/dist
