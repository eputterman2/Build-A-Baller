{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@shared/index": ["../shared/src/index.ts"],
      "@shared/*": ["../shared/src/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../shared/src/**/*.ts"]
}
